import heapq

class Node:
    def __init__(self, freq, char=None, left=None, right=None):
        self.freq = freq
        self.char = char
        self.left = left
        self.right = right

    def __lt__(self, other):
        return self.freq < other.freq

def generate(node, code, result):
    if node.char:
        result[node.char] = code
        return

    generate(node.left, code + "0", result)
    generate(node.right, code + "1", result)

chars = ['a','b','c','d']
freq = [5,9,12,13]

heap = []

for c, f in zip(chars, freq):
    heapq.heappush(heap, Node(f, c))

while len(heap) > 1:
    a = heapq.heappop(heap)
    b = heapq.heappop(heap)
    heapq.heappush(heap, Node(a.freq+b.freq, left=a, right=b))

root = heap[0]
codes = {}

generate(root, "", codes)

print(codes)